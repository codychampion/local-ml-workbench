# MLOps Workspace Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# Phase 1: Most values have sensible defaults for local development

# =============================================================================
# Environment Settings
# =============================================================================
MLOPS_ENV=development
DEBUG=true

# =============================================================================
# Compute Settings (Phase 1: CPU-only)
# =============================================================================
COMPUTE_DEVICE=cpu
NUM_WORKERS=2

# =============================================================================
# Weights & Biases Configuration
# =============================================================================
# Phase 1: Offline mode (no API key required)
WANDB_MODE=offline
WANDB_PROJECT=mlops-workspace
WANDB_DIR=./outputs/wandb

# PHASE 2/3 TODO: Online mode configuration
# WANDB_API_KEY=your-wandb-api-key
# WANDB_ENTITY=your-team-name
# WANDB_MODE=online

# =============================================================================
# FiftyOne Configuration
# =============================================================================
FIFTYONE_DATABASE_DIR=./data/fiftyone
FIFTYONE_DEFAULT_DATASET_DIR=./data/fiftyone/datasets
FIFTYONE_PORT=5151
FIFTYONE_ADDRESS=0.0.0.0

# =============================================================================
# Backblaze B2 Configuration (Phase 1: Mocked)
# =============================================================================
# Phase 1: Local manifest-based mock
B2_LOCAL_MANIFEST=.b2_local_manifest.json
B2_LOCAL_DATA_DIR=./data/raw
B2_MAX_REQUESTS_PER_MIN=100
B2_BUCKET_NAME=mlops-data-bucket

# PHASE 2/3 TODO: Real B2 credentials
# B2_APPLICATION_KEY_ID=your-key-id
# B2_APPLICATION_KEY=your-application-key

# =============================================================================
# PHASE 2/3 TODO: Prefect Configuration
# =============================================================================
# PREFECT_API_URL=http://localhost:4200/api
# PREFECT_API_KEY=your-prefect-api-key

# =============================================================================
# PHASE 2/3 TODO: SkyPilot Configuration
# =============================================================================
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# GCP_PROJECT_ID=your-gcp-project
# AZURE_SUBSCRIPTION_ID=your-azure-subscription
